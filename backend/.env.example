# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_teaching
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_teaching

# Redis 配置
REDIS_URL=redis://cache:6379/0

# ChromaDB 配置
CHROMA_PERSIST_DIR=chroma_data

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时

# ========== 阿里云百炼 API ==========
DASHSCOPE_API_KEY=your-dashscope-api-key

# LLM 模型选择
# 可选: qwen-plus, qwen-turbo, qwen-max, qwen3.5-plus 等
LLM_MODEL=qwen-plus

# Embedding 模型选择
# 可选: tongyi-embedding-vision-flash, tongyi-embedding-v2 等
EMBEDDING_MODEL=tongyi-embedding-vision-flash

# Rerank 重排序模型选择
# 可选: qwen3-vl-rerank (多模态), qwen3-rerank (纯文本)
RERANK_MODEL=qwen3-vl-rerank

# ========== 短信服务（国阳云） ==========
SMS_APPCODE=your-sms-appcode

# ========== 其他 API（可选） ==========
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ========== 网络搜索 API ==========
# Tavily API（用于联网搜索）
# 申请地址: https://tavily.com/
# 免费额度: 1000次/月
TAVILY_API_KEY=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


# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ========== html小游戏DeepseekAPI ==========
HTML_LLM_API_KEY=sk-62e64862c5174f7a875467918b761b29
HTML_LLM_BASE_URL=https://api.deepseek.com
HTML_LLM_MODEL=deepseek-chat
#上传目录
HTML_UPLOAD_DIR=uploads

# ========== 数据分析（图表中文字体，可选）==========
# 若生成图表中文显示为方块，可指定一个系统字体文件路径（ttf/ttc/otf）
DATA_ANALYSIS_FONT_PATH=media/fonts/SourceHanSansSC-Regular.otf

# ========== Neo4j Graph Database ==========
# Neo4j Aura 连接信息（仅系统知识库图检索使用）
NEO4J_URI=neo4j+s://6ad2eb8b.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=0ta8nf3kYaO4CHD7k9mWPYJZAogW2N7Na3GdB1dd87M

# ========== Dify 工作流（资源发现页 /resource-search）==========
# 在 Dify 应用「资源推荐助手」-> 访问 API 中获取 API Key
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_RESOURCE_WORKFLOW_API_KEY=

# ========== 讯飞 AI 虚拟人（在线驱动 / VMS Web SDK & Web API）==========
# 控制台创建应用后填写；形象 ID 在「形象列表」中查看
# 讯飞应用 APPID（用于 header.app_id）
IFLYTEK_VMS_APP_ID=d83fb015
# 讯飞应用 APIKey（参与 HMAC 鉴权）
IFLYTEK_VMS_API_KEY=face35b51318938434eb1c75d20969ce
# 讯飞应用 APISecret（参与 HMAC 鉴权，务必保密）
IFLYTEK_VMS_API_SECRET=NDQzN2I0MTQxNTU2YjFiMDMyYThmZmNi
# 控制台“接口服务ID”（用于管理与排查，可选）
IFLYTEK_VMS_SERVICE_ID=297559537290973184
# 默认形象 ID（前端未传 avatar_id 时使用）
IFLYTEK_VMS_DEFAULT_AVATAR_ID=111306001
# 讯飞 VMS 服务域名（通常固定为华东节点）
IFLYTEK_VMS_HOST=vms.cn-huadong-1.xf-yun.com
# 默认视频宽度（启动 vms2d_start 时使用）
IFLYTEK_VMS_DEFAULT_WIDTH=1280
# 默认视频高度（启动 vms2d_start 时使用）
IFLYTEK_VMS_DEFAULT_HEIGHT=720
# 默认流协议：xrtc（推荐）或 rtmp
IFLYTEK_VMS_STREAM_PROTOCOL=xrtc
# Avatar SDK setGlobalParams.tts.vcn 必填（发音人 ID，与控制台一致）
IFLYTEK_AVATAR_TTS_VCN=x4_panting

# ========== LightRAG ==========
# LightRAG 本地工作目录（默认自动锚定 backend/lightrag_data/，一般无需修改）
# LIGHTRAG_WORKING_DIR=lightrag_data

