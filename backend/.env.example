# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_teaching
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_teaching

# Redis 配置
REDIS_URL=redis://cache:6379/0

# ChromaDB 配置
CHROMA_PERSIST_DIR=chroma_data

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时

# ========== 阿里云百炼 API ==========
DASHSCOPE_API_KEY=your-dashscope-api-key

# LLM 模型选择
# 可选: qwen-plus, qwen-turbo, qwen-max, qwen3.5-plus 等
LLM_MODEL=qwen-plus

# Embedding 模型选择
# 可选: tongyi-embedding-vision-flash, tongyi-embedding-v2 等
EMBEDDING_MODEL=tongyi-embedding-vision-flash

# Rerank 重排序模型选择
# 可选: qwen3-vl-rerank (多模态), qwen3-rerank (纯文本)
RERANK_MODEL=qwen3-vl-rerank

# ========== 短信服务（国阳云） ==========
SMS_APPCODE=your-sms-appcode

# ========== 其他 API（可选） ==========
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ========== 网络搜索 API ==========
# Tavily API（用于联网搜索）
# 申请地址: https://tavily.com/
# 免费额度: 1000次/月
TAVILY_API_KEY=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


# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ========== html小游戏DeepseekAPI ==========
HTML_LLM_API_KEY=sk-your-deepseek-api-key
HTML_LLM_BASE_URL=https://api.deepseek.com
HTML_LLM_MODEL=deepseek-chat
#上传目录
HTML_UPLOAD_DIR=uploads

# ========== SiliconFlow AI 生图 ==========
# SiliconFlow API（用于 Kolors AI 生图）
# 申请地址: https://siliconflow.cn/
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# ========== Docmee PPT 生成 API ==========
# Docmee API（用于 AI PPT 生成）
# 申请地址: https://open.docmee.cn/
# 免费额度: 根据套餐而定
DOCMEE_API_KEY=ak_your_docmee_api_key
DOCMEE_TRUST_ENV=false
DOCMEE_REQUEST_TIMEOUT_SECONDS=60
DOCMEE_GENERATE_PPTX_TIMEOUT_SECONDS=600
DOCMEE_PPTX_POLL_ATTEMPTS=8
DOCMEE_PPTX_POLL_DELAY_SECONDS=2.0

# ========== Unsplash 图片搜索 API ==========
# Unsplash API（用于 PPT 自动配图）
# 申请地址: https://unsplash.com/developers
# 免费额度: 50次/小时
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ========== 数据分析（图表中文字体，可选）==========
# 若生成图表中文显示为方块，可指定一个系统字体文件路径（ttf/ttc/otf）
DATA_ANALYSIS_FONT_PATH=media/fonts/SourceHanSansSC-Regular.otf

# ========== Neo4j Graph Database ==========
# Neo4j Aura 连接信息（仅系统知识库图检索使用）
NEO4J_URI=neo4j+s://your-neo4j-uri.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ========== Dify 工作流（资源发现页 /resource-search）==========
# 在 Dify 应用「资源推荐助手」-> 访问 API 中获取 API Key
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_RESOURCE_WORKFLOW_API_KEY=your-dify-api-key

# ========== LightRAG ==========
# LightRAG 本地工作目录（默认自动锚定 backend/lightrag_data/，一般无需修改）
# LIGHTRAG_WORKING_DIR=lightrag_data

# ========== 阿里云 OSS（PPT/课件文件存储）==========
# OSS Endpoint，如 https://oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# Bucket 名称
OSS_BUCKET=your-oss-bucket
# RAM 用户 AccessKey（建议使用 RAM 子用户，权限仅限 OSS）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# ========== Banana-slides AI 配置（PPT生成服务）==========
# AI Provider 格式：gemini（默认）/ openai / anthropic
AI_PROVIDER_FORMAT=gemini

# Gemini 配置（当 AI_PROVIDER_FORMAT=gemini 时使用）
# 国内建议使用代理如 https://aihubmix.com/gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_API_BASE=https://aihubmix.com/gemini
GENAI_TIMEOUT=300.0
GENAI_MAX_RETRIES=2

# OpenAI 格式配置（当 AI_PROVIDER_FORMAT=openai 时使用）
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TIMEOUT=300.0
OPENAI_MAX_RETRIES=2

# Anthropic 格式配置（当 AI_PROVIDER_FORMAT=anthropic 时使用）
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=8192

# 各模型具体选择（优先级：独立配置 > 全局 AI_PROVIDER_FORMAT）
# 文本模型（如 gemini-3-flash-preview）
TEXT_MODEL=gemini-3-flash-preview
# 图片生成模型（如 gemini-3-pro-image-preview）
IMAGE_MODEL=gemini-3-pro-image-preview
# 图片识别/描述模型（用于解析上传文件中的图片内容）
IMAGE_CAPTION_MODEL=gemini-3-flash-preview

# 国内各厂商 API Key（按需配置）
DOUBAO_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# 国内镜像代理（遇网络问题时可配置）
# GOOGLE_API_BASE=https://aihubmix.com/gemini

# 并发控制
MAX_DESCRIPTION_WORKERS=5
MAX_IMAGE_WORKERS=8

# MinerU 文档解析服务（用于"文件生成"路径，https://mineru.net 申请）
MINERU_TOKEN=your-mineru-token
MINERU_API_BASE=https://mineru.net

# 可编辑 PPTX 导出（文字提取，百度 OCR，百度inpaint）
BAIDU_API_KEY=your-baidu-api-key

# 输出语言：zh / ja / en / auto
OUTPUT_LANGUAGE=zh

