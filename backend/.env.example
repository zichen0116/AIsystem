# ====================== 基础应用配置 ======================
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ====================== 数据库配置 ======================
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_teaching
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_teaching
# Redis
REDIS_URL=redis://cache:6379/0
# ChromaDB
CHROMA_PERSIST_DIR=chroma_data
# Neo4j 图数据库
NEO4J_URI=neo4j+s://your-neo4j-uri.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ====================== JWT 认证 ======================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====================== 阿里云百炼 API ======================
DASHSCOPE_API_KEY=your-dashscope-api-key

# ====================== 模型配置 ======================
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=tongyi-embedding-vision-flash
RERANK_MODEL=qwen3-vl-rerank
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry
REHEARSAL_IMAGE_MODEL=qwen-image-2.0
REHEARSAL_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
REHEARSAL_IMAGE_SIZE=1280*720
REHEARSAL_IMAGE_TIMEOUT_SECONDS=120
ASR_MODEL=qwen3-asr-flash
VISION_MODEL=qwen-vl-plus

# ====================== 阿里云 OSS 对象存储 ======================
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-oss-bucket
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# ====================== 网络搜索 API ======================
TAVILY_API_KEY=your-tavily-api-key

# ====================== 短信 & 邮件服务 ======================
# 国阳云短信
SMS_APPCODE=your-sms-appcode
# QQ SMTP 邮件
EMAIL_SMTP_USER=your-email@qq.com
EMAIL_SMTP_PASSWORD=your-email-smtp-password

# ====================== Banana-slides AI PPT 生成 ======================
AI_PROVIDER_FORMAT=gemini
# Gemini 代理配置
GOOGLE_API_KEY=your-google-api-key
GOOGLE_API_BASE=https://aihubmix.com/gemini
GENAI_TIMEOUT=300.0
GENAI_MAX_RETRIES=2
# OpenAI 代理配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_TIMEOUT=300.0
OPENAI_MAX_RETRIES=2
# Anthropic 配置
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=8192
# 模型指定
TEXT_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-3-pro-image-preview
IMAGE_CAPTION_MODEL=gemini-3-flash-preview
# 国内厂商 API（按需填写）
DOUBAO_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=

# ====================== 文档解析 & OCR ======================
# MinerU 文档解析
MINERU_TOKEN=your-mineru-token
MINERU_API_BASE=https://mineru.net
# 百度 OCR（PPT 可编辑导出）
BAIDU_API_KEY=your-baidu-api-key

# ====================== PPT 生态服务 ======================
# Docmee PPT 生成
DOCMEE_API_KEY=your-docmee-api-key
DOCMEE_TRUST_ENV=false
DOCMEE_REQUEST_TIMEOUT_SECONDS=60
DOCMEE_GENERATE_PPTX_TIMEOUT_SECONDS=600
DOCMEE_PPTX_POLL_ATTEMPTS=8
DOCMEE_PPTX_POLL_DELAY_SECONDS=2.0
# Unsplash 图片搜索
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ====================== AI 生图（SiliconFlow）======================
SILICONFLOW_API_KEY=your-siliconflow-api-key

# ====================== 讯飞 AI 虚拟人 ======================
IFLYTEK_VMS_APP_ID=your-iflytek-vms-app-id
IFLYTEK_VMS_API_KEY=your-iflytek-vms-api-key
IFLYTEK_VMS_API_SECRET=your-iflytek-vms-api-secret
IFLYTEK_VMS_SERVICE_ID=your-iflytek-vms-service-id
IFLYTEK_VMS_DEFAULT_AVATAR_ID=111306001
IFLYTEK_VMS_HOST=vms.cn-huadong-1.xf-yun.com
IFLYTEK_VMS_DEFAULT_WIDTH=1280
IFLYTEK_VMS_DEFAULT_HEIGHT=720
IFLYTEK_VMS_STREAM_PROTOCOL=xrtc
IFLYTEK_AVATAR_TTS_VCN=x4_panting

# ====================== 其他扩展服务 ======================
# Dify 工作流
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_RESOURCE_WORKFLOW_API_KEY=your-dify-api-key
# LightRAG
# LIGHTRAG_WORKING_DIR=lightrag_data
# 数据分析中文字体
DATA_ANALYSIS_FONT_PATH=media/fonts/SourceHanSansSC-Regular.otf
# HTML 小游戏 Deepseek
HTML_LLM_API_KEY=your-deepseek-api-key
HTML_LLM_BASE_URL=https://api.deepseek.com
HTML_LLM_MODEL=deepseek-chat
HTML_UPLOAD_DIR=uploads

# ====================== 并发控制 ======================
MAX_DESCRIPTION_WORKERS=5
MAX_IMAGE_WORKERS=8

# ====================== 输出语言 ======================
OUTPUT_LANGUAGE=zh
