# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_teaching
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_teaching

# Redis 配置
REDIS_URL=redis://cache:6379/0

# ChromaDB 配置
CHROMA_PERSIST_DIR=chroma_data

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时

# ========== 阿里云百炼 API ==========
DASHSCOPE_API_KEY=your-dashscope-api-key

# LLM 模型选择
# 可选: qwen-plus, qwen-turbo, qwen-max, qwen3.5-plus 等
LLM_MODEL=qwen-plus

# Embedding 模型选择
# 可选: tongyi-embedding-vision-flash, tongyi-embedding-v2 等
EMBEDDING_MODEL=tongyi-embedding-vision-flash

# ========== 其他 API（可选） ==========
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ========== 网络搜索 API ==========
# Tavily API（用于联网搜索）
# 申请地址: https://tavily.com/
# 免费额度: 1000次/月
TAVILY_API_KEY=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


# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
